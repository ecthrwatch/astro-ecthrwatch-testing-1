---
import { t } from "../i18n/utils";
import type { Locale } from "../i18n/translations";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const name = t(locale, "footer.copyright.name");
const url = t(locale, "footer.copyright.url");
---
<footer class="footer">
  <div class="footer-org">{t(locale, "site.org")}</div>
  <div>&copy; 2021-2026 <a href={url}>{name}</a></div>
</footer>
