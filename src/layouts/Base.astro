---
import { t } from "../i18n/utils";
import type { Locale } from "../i18n/translations";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t(locale, "site.title")}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
