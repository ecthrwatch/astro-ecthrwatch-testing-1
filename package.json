{
  "name": "astro-i18n-minimal",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n en,fr,zh -c blue,magenta,green \"npm run dev:en\" \"npm run dev:fr\" \"npm run dev:zh\"",
    "dev:en": "astro dev --port 4321",
    "dev:fr": "astro dev --port 4322",
    "dev:zh": "astro dev --port 4323",
    "build": "astro build",
    "preview": "astro preview"
  },
  "dependencies": {
    "astro": "^6.1.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
