---
import Base from "@shared/layouts/Base.astro";
import { getCollection, render } from "astro:content";
import type { Locale } from "@shared/i18n/translations";

export async function getStaticPaths() {
  const events = await getCollection("timeline");
  return events.map((event) => ({
    params: { slug: event.data.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const locale = Astro.locals.locale as Locale;
const { Content } = await render(event);
---
<Base locale={locale}>
  <article class="page-container">
    <h1>{event.data.title}</h1>
    <div class="event-content">
      <Content />
    </div>
  </article>
</Base>

<style>
  .page-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .page-container h1 {
    margin-bottom: 1.5rem;
    font-size: 1.8rem;
    line-height: 1.3;
  }

  .event-content {
    line-height: 1.7;
  }

  .event-content p {
    margin-bottom: 1rem;
  }

  .event-content blockquote {
    border-left: 3px solid var(--color-nav-border);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-text);
    opacity: 0.85;
  }

  .event-content hr {
    border: none;
    border-top: 1px solid var(--color-nav-border);
    margin: 1.5rem 0;
  }

  .event-content figure {
    margin: 1.5rem 0;
  }
</style>
